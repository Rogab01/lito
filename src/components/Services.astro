---
const services = [
  {
    title: 'Impresión Offset',
    description: 'Alta calidad en grandes tirajes: revistas, catálogos, folletos y más con colores precisos.',
    icon: 'offset',
  },
  {
    title: 'Impresión Digital',
    description: 'Tirajes pequeños y personalizados con entrega rápida y acabados profesionales.',
    icon: 'digital',
  },
  {
    title: 'Gran Formato',
    description: 'Lonas, vinilos, pendones y señalización exterior con tintas de máxima durabilidad.',
    icon: 'large',
  },
  {
    title: 'Diseño Gráfico',
    description: 'Identidad de marca, branding, diagramación editorial y piezas publicitarias creativas.',
    icon: 'design',
  },
  {
    title: 'Empaques y Etiquetas',
    description: 'Diseño y producción de cajas, empaques promocionales y etiquetas adhesivas.',
    icon: 'packaging',
  },
  {
    title: 'Publicidad Exterior',
    description: 'Vallas, rotulación vehicular, stands y material POP que genera recordación.',
    icon: 'outdoor',
  },
];

const iconPaths: Record<string, string> = {
  offset: 'M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z',
  digital: 'M2 3h20v14H2z M8 21h8 M12 17v4',
  large: 'M3 3h18v18H3z M3 9h18 M9 21V9',
  design: 'M12 19l7-7 3 3-7 7-3-3z M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z M2 2l7.586 7.586 M11 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
  packaging: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.27 6.96L12 12.01l8.73-5.05 M12 22.08V12',
  outdoor: 'M4 22h16 M6 18h12 M8 14h8 M10 2h4v12h-4z',
};
---

<section class="services section" id="servicios">
  <div class="container">
    <header class="section-header fade-in">
      <span class="eyebrow">Nuestros servicios</span>
      <h2>Soluciones integrales de impresión y publicidad</h2>
      <p>
        Todo lo que tu marca necesita bajo un mismo techo, con asesoría experta desde el diseño
        hasta la entrega final.
      </p>
    </header>

    <div class="services-grid">
      {services.map((service, idx) => (
        <article class="service-card fade-in" style={`transition-delay: ${idx * 80}ms`}>
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[service.icon]} />
            </svg>
          </div>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
          <a href="#contacto" class="service-link" aria-label={`Más información sobre ${service.title}`}>
            Más información
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background: #fff;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    position: relative;
    padding: 2rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  .service-icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(225, 29, 72, 0.1), rgba(245, 158, 11, 0.1));
    color: var(--color-primary);
    margin-bottom: 1.25rem;
  }

  .service-icon svg {
    width: 28px;
    height: 28px;
  }

  .service-card h3 {
    margin-bottom: 0.625rem;
  }

  .service-card p {
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
  }

  .service-link svg {
    width: 16px;
    height: 16px;
    transition: transform var(--transition);
  }

  .service-link:hover svg {
    transform: translateX(4px);
  }
</style>
