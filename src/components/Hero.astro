---
const stats = [
  { value: '+15', label: 'Años de experiencia' },
  { value: '+1.2k', label: 'Clientes satisfechos' },
  { value: '+8k', label: 'Proyectos entregados' },
  { value: '24/7', label: 'Atención personalizada' },
];
---

<section class="hero" id="inicio">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-pattern"></div>
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-inner">
    <span class="badge fade-in">
      <span class="badge-dot"></span>
      Bienvenido a Lito Latina Editores
    </span>
    <h1 class="fade-in">
      Litografía y publicidad<br />
      <span class="highlight">que impulsan tu marca</span>
    </h1>
    <p class="slogan fade-in">
      "Calidad y Responsabilidad nos hacen diferentes"
    </p>
    <p class="hero-text fade-in">
      Más de 15 años imprimiendo las ideas que construyen marcas en toda Latinoamérica.
      Combinamos tecnología de última generación con diseño creativo y atención personalizada.
    </p>
    <div class="hero-actions fade-in">
      <a href="#contacto" class="btn btn-primary">Solicita tu cotización</a>
      <a href="#servicios" class="btn btn-outline">Conoce nuestros servicios</a>
    </div>
  </div>

  <div class="hero-stats">
    <div class="container">
      <ul class="stats" role="list">
        {stats.map((s, i) => (
          <li class="fade-in" style={`transition-delay: ${i * 80}ms`}>
            <strong>{s.value}</strong>
            <span>{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="hero-wave">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,60 C240,110 480,10 720,40 C960,70 1200,120 1440,60 L1440,120 L0,120 Z" fill="#ffffff" />
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: calc(76px + 5rem);
    padding-bottom: 0;
    color: #fff;
    isolation: isolate;
    overflow: hidden;
    background: var(--gradient-hero);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.07) 0,
        rgba(255, 255, 255, 0.07) 1px,
        transparent 1px,
        transparent 6px
      );
    mask-image: radial-gradient(ellipse at right, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at right, black 0%, transparent 70%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.15), transparent 45%),
      radial-gradient(circle at 85% 80%, rgba(0, 0, 0, 0.25), transparent 50%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 900px;
    padding-top: 2rem;
    padding-bottom: 5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 1.25rem;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: var(--radius-pill);
    margin-bottom: 1.75rem;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.25);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.5); }
    50% { box-shadow: 0 0 0 10px rgba(255, 255, 255, 0); }
  }

  .hero h1 {
    color: #fff;
    margin-bottom: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .highlight {
    display: inline-block;
    position: relative;
  }

  .highlight::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.1em;
    width: 100%;
    height: 0.2em;
    background: rgba(255, 255, 255, 0.25);
    z-index: -1;
    border-radius: 4px;
  }

  .slogan {
    font-style: italic;
    font-size: 1.15rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.92);
    margin-bottom: 1rem;
  }

  .hero-text {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 680px;
    margin: 0 auto 2.5rem;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-stats {
    position: relative;
    z-index: 1;
    padding-bottom: 5rem;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    list-style: none;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .stats li {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .stats li + li {
    border-left: 1px solid rgba(255, 255, 255, 0.15);
  }

  .stats strong {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    line-height: 1;
  }

  .stats span {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 0.5rem;
  }

  @media (max-width: 720px) {
    .stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 1rem;
    }
    .stats li + li {
      border-left: none;
    }
    .stats li:nth-child(even) {
      border-left: 1px solid rgba(255, 255, 255, 0.15);
    }
  }

  .hero-wave {
    width: 100%;
    line-height: 0;
  }

  .hero-wave svg {
    width: 100%;
    height: 90px;
    display: block;
  }

  @media (max-width: 480px) {
    .hero-actions .btn {
      width: 100%;
    }
  }
</style>
