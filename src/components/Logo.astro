---
interface Props {
  showTagline?: boolean;
  variant?: 'light' | 'dark';
  href?: string;
  size?: 'sm' | 'md' | 'lg';
}

const {
  showTagline = false,
  variant = 'dark',
  href = '#inicio',
  size = 'md',
} = Astro.props;

const stripeCount = 22;
const stripes = Array.from({ length: stripeCount }, (_, i) => i);
---

<a href={href} class:list={['logo', `logo-${variant}`, `logo-${size}`]} aria-label="Lito Latina Editores - Inicio">
  <span class="logo-wordmark">
    <span class="logo-row">
      <span class="logo-lito">LITO</span>
      <svg class="logo-map" viewBox="0 0 40 58" aria-hidden="true" role="presentation">
        <defs>
          <clipPath id="sa-clip">
            <path d="M20 1 C23 1 27 3 29 7 C31 11 33 14 34 18 C35 22 34 26 32 30 C30 34 28 37 27 40 C26 43 25 46 23 50 C22 53 20 56 18 57 C16 56 14 52 13 48 C12 44 10 40 9 36 C8 32 7 28 8 24 C9 20 10 16 12 12 C14 8 17 4 20 1 Z" />
          </clipPath>
        </defs>
        <g clip-path="url(#sa-clip)">
          {stripes.map((i) => (
            <line
              x1="0"
              x2="40"
              y1={2 + i * 2.6}
              y2={2 + i * 2.6}
              stroke="currentColor"
              stroke-width="1.4"
            />
          ))}
        </g>
      </svg>
    </span>
    <span class="logo-latina">LATINA</span>
    <span class="logo-editores">EDITORES</span>
    {showTagline && (
      <span class="logo-tagline">Calidad y Responsabilidad nos hacen diferentes</span>
    )}
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    line-height: 0.95;
    text-decoration: none;
  }

  .logo-wordmark {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15em;
  }

  .logo-row {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.35em;
  }

  .logo-lito {
    color: var(--color-primary);
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .logo-latina {
    color: var(--color-green);
    font-weight: 800;
    letter-spacing: 0.06em;
  }

  .logo-editores {
    font-size: 0.42em;
    font-weight: 600;
    letter-spacing: 0.38em;
    color: var(--color-secondary);
    margin-top: 0.1em;
  }

  .logo-tagline {
    font-family: var(--font-sans);
    font-size: 0.32em;
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
    margin-top: 0.35em;
    font-weight: 500;
  }

  .logo-map {
    width: 1em;
    height: 1.45em;
    color: var(--color-primary);
    margin-top: -0.05em;
    flex-shrink: 0;
  }

  /* Sizes — control overall size with font-size */
  .logo-sm { font-size: 1.25rem; }
  .logo-md { font-size: 1.5rem; }
  .logo-lg { font-size: 2.5rem; }

  /* Light variant (for dark backgrounds) */
  .logo-light .logo-lito { color: #f87171; }
  .logo-light .logo-latina { color: #4ade80; }
  .logo-light .logo-editores { color: rgba(241, 245, 249, 0.85); }
  .logo-light .logo-map { color: #f87171; }
  .logo-light .logo-tagline { color: #f87171; }
</style>
