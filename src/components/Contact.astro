---
const contactInfo = [
  {
    label: 'Llámanos',
    value: '+57 300 123 4567',
    href: 'tel:+573001234567',
    icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z',
  },
  {
    label: 'Escríbenos',
    value: 'contacto@litolatina.com',
    href: 'mailto:contacto@litolatina.com',
    icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6',
  },
  {
    label: 'Visítanos',
    value: 'Cra 50 #120-45, Bogotá',
    href: '#',
    icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z',
  },
];
---

<section class="contact section" id="contacto">
  <div class="container">
    <div class="contact-card fade-in">
      <div class="contact-info">
        <span class="eyebrow">Contacto</span>
        <h2>¿Listo para darle vida a tu próximo proyecto?</h2>
        <p>
          Cuéntanos tu idea y nuestro equipo te enviará una cotización personalizada en menos de
          24 horas hábiles.
        </p>

        <ul class="info-list" role="list">
          {contactInfo.map((item) => (
            <li>
              <span class="info-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d={item.icon} />
                </svg>
              </span>
              <div>
                <small>{item.label}</small>
                <a href={item.href}>{item.value}</a>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <form class="contact-form" id="contactForm" novalidate>
        <h3>Solicita tu cotización</h3>

        <div class="form-grid">
          <div class="field">
            <label for="name">Nombre completo</label>
            <input type="text" id="name" name="name" required autocomplete="name" />
          </div>

          <div class="field">
            <label for="email">Correo electrónico</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>

          <div class="field">
            <label for="phone">Teléfono</label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" />
          </div>

          <div class="field">
            <label for="service">Servicio de interés</label>
            <select id="service" name="service" required>
              <option value="">Selecciona una opción</option>
              <option value="offset">Impresión Offset</option>
              <option value="digital">Impresión Digital</option>
              <option value="large">Gran Formato</option>
              <option value="design">Diseño Gráfico</option>
              <option value="packaging">Empaques</option>
              <option value="outdoor">Publicidad Exterior</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label for="message">Cuéntanos sobre tu proyecto</label>
          <textarea id="message" name="message" rows="4" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary form-submit">
          Enviar mensaje
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>

        <p class="form-status" id="formStatus" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-bg-alt);
  }

  .contact-card {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    background: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
  }

  .contact-info {
    padding: clamp(2rem, 4vw, 3rem);
    background: linear-gradient(160deg, var(--color-secondary), #1e293b);
    color: var(--color-text-light);
    position: relative;
    overflow: hidden;
  }

  .contact-info::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -30%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(225, 29, 72, 0.25), transparent 70%);
    border-radius: 50%;
  }

  .contact-info > * { position: relative; }

  .contact-info .eyebrow {
    color: var(--color-primary-light);
  }

  .contact-info h2 {
    color: #fff;
    margin: 0.75rem 0 1rem;
  }

  .contact-info > p {
    color: rgba(241, 245, 249, 0.8);
    margin-bottom: 2.5rem;
  }

  .info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-list li {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .info-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(225, 29, 72, 0.2);
    color: var(--color-primary-light);
  }

  .info-icon svg { width: 20px; height: 20px; }

  .info-list small {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(241, 245, 249, 0.6);
    margin-bottom: 0.25rem;
  }

  .info-list a {
    font-weight: 500;
    color: #fff;
  }

  .info-list a:hover {
    color: var(--color-primary-light);
  }

  .contact-form {
    padding: clamp(2rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-form h3 {
    margin-bottom: 0.25rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .field label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .field input,
  .field select,
  .field textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    font: inherit;
    color: var(--color-text);
    background: #fff;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(225, 29, 72, 0.12);
  }

  .field textarea {
    resize: vertical;
    min-height: 110px;
  }

  .form-submit {
    align-self: flex-start;
  }

  .form-submit svg {
    width: 18px;
    height: 18px;
  }

  .form-status {
    font-size: 0.9rem;
    min-height: 1.25rem;
    font-weight: 500;
  }

  .form-status.success { color: #059669; }
  .form-status.error { color: #dc2626; }

  @media (max-width: 880px) {
    .contact-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
    .form-submit {
      width: 100%;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const status = document.getElementById('formStatus');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!status) return;

    if (!form.checkValidity()) {
      status.textContent = 'Por favor completa los campos obligatorios.';
      status.className = 'form-status error';
      return;
    }

    status.textContent = 'Enviando...';
    status.className = 'form-status';

    setTimeout(() => {
      status.textContent = '¡Gracias! Te contactaremos muy pronto.';
      status.className = 'form-status success';
      form.reset();
    }, 700);
  });
</script>
