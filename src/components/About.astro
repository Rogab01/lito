---
const features = [
  {
    title: 'Tecnología de punta',
    description: 'Maquinaria offset y digital de última generación para acabados impecables.',
  },
  {
    title: 'Equipo experto',
    description: 'Diseñadores y técnicos con más de una década de experiencia en el sector.',
  },
  {
    title: 'Entregas puntuales',
    description: 'Cumplimos los tiempos pactados porque sabemos que tu campaña no espera.',
  },
  {
    title: 'Calidad garantizada',
    description: 'Control de calidad en cada etapa del proceso, desde el arte hasta el empaque.',
  },
];
---

<section class="about section" id="nosotros">
  <div class="container about-inner">
    <div class="about-visual fade-in">
      <div class="visual-block block-primary">
        <span class="visual-label">+15 años</span>
        <strong>Imprimiendo confianza</strong>
      </div>
      <div class="visual-block block-dark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2L2 7l10 5 10-5-10-5z M2 17l10 5 10-5 M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Procesos certificados</span>
      </div>
      <div class="visual-block block-accent">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 12V22H4V12 M22 7H2V12H22V7 M12 22V7 M12 7H7.5A2.5 2.5 0 0 1 5 4.5A2.5 2.5 0 0 1 7.5 2C11 2 12 7 12 7 M12 7H16.5A2.5 2.5 0 0 0 19 4.5A2.5 2.5 0 0 0 16.5 2C13 2 12 7 12 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Soluciones a medida</span>
      </div>
    </div>

    <div class="about-content">
      <span class="eyebrow fade-in">Sobre nosotros</span>
      <h2 class="fade-in">Una litografía moderna con alma creativa</h2>
      <p class="fade-in">
        En <strong>Lito Latina Editores</strong> llevamos más de una década transformando ideas
        en piezas impresas de alto impacto en toda Latinoamérica. Combinamos el oficio tradicional
        de la litografía con las últimas tecnologías digitales para ofrecer soluciones publicitarias
        memorables.
      </p>

      <ul class="features" role="list">
        {features.map((feature, idx) => (
          <li class="fade-in" style={`transition-delay: ${idx * 100}ms`}>
            <span class="check" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          </li>
        ))}
      </ul>

      <a href="#contacto" class="btn btn-primary fade-in">Hablemos de tu proyecto</a>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--color-bg-alt);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-visual {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 180px);
    gap: 1rem;
  }

  .visual-block {
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    box-shadow: var(--shadow-md);
    overflow: hidden;
    position: relative;
  }

  .visual-block svg {
    width: 36px;
    height: 36px;
    margin-bottom: 0.75rem;
  }

  .visual-block span {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .block-primary {
    grid-row: span 2;
    background: linear-gradient(160deg, var(--color-primary), var(--color-primary-dark));
    color: #fff;
  }
  .block-primary .visual-label {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.85;
    margin-bottom: 0.25rem;
    font-weight: 600;
  }
  .block-primary strong {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1.15;
  }

  .block-dark {
    background: var(--color-bg-dark);
    color: var(--color-text-light);
  }

  .block-accent {
    background: linear-gradient(160deg, var(--color-green), var(--color-green-dark));
    color: #fff;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .about-content > p {
    color: var(--color-text-muted);
    margin: 1.25rem 0 2rem;
    font-size: 1.05rem;
  }

  .features {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }

  .features li {
    display: flex;
    gap: 0.875rem;
  }

  .check {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    background: rgba(220, 38, 38, 0.1);
    color: var(--color-primary);
    border-radius: 50%;
  }

  .check svg {
    width: 16px;
    height: 16px;
  }

  .features h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .features p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 960px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-visual {
      grid-template-rows: repeat(2, 160px);
      max-width: 520px;
    }
  }

  @media (max-width: 520px) {
    .features {
      grid-template-columns: 1fr;
    }
  }
</style>
