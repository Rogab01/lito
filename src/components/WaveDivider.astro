---
interface Props {
  from?: string;
  to?: string;
  flip?: boolean;
  variant?: 'wave' | 'curve';
  height?: string;
}

const {
  from = '#ffffff',
  to = '#f7f5f2',
  flip = false,
  variant = 'wave',
  height = '90px',
} = Astro.props;

const paths: Record<string, string> = {
  wave: 'M0,64 C240,112 480,16 720,48 C960,80 1200,128 1440,80 L1440,160 L0,160 Z',
  curve: 'M0,96 C480,0 960,0 1440,96 L1440,160 L0,160 Z',
};
---

<div
  class:list={['wave-divider', { flipped: flip }]}
  style={`background:${from};--wd-height:${height}`}
  aria-hidden="true"
>
  <svg viewBox="0 0 1440 160" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d={paths[variant]} fill={to} />
  </svg>
</div>

<style>
  .wave-divider {
    display: block;
    width: 100%;
    height: var(--wd-height, 90px);
    line-height: 0;
  }

  .wave-divider svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .wave-divider.flipped svg {
    transform: scaleY(-1);
  }
</style>
