---
const projects = [
  {
    title: 'Catálogo Editorial',
    category: 'Offset',
    gradient: 'linear-gradient(135deg, #dc1e1e, #6b0e0e)',
    tag: 'Editorial',
  },
  {
    title: 'Campaña Lanzamiento',
    category: 'Gran formato',
    gradient: 'linear-gradient(135deg, #0f7a3a, #052e14)',
    tag: 'Publicidad',
  },
  {
    title: 'Empaque Premium',
    category: 'Packaging',
    gradient: 'linear-gradient(135deg, #0f172a, #8b1616)',
    tag: 'Empaque',
  },
  {
    title: 'Identidad Corporativa',
    category: 'Branding',
    gradient: 'linear-gradient(135deg, #dc1e1e, #0f7a3a)',
    tag: 'Diseño',
  },
  {
    title: 'Material POP',
    category: 'Publicidad',
    gradient: 'linear-gradient(135deg, #1ba560, #0f7a3a)',
    tag: 'POP',
  },
  {
    title: 'Señalización Urbana',
    category: 'Exterior',
    gradient: 'linear-gradient(135deg, #052e14, #dc1e1e)',
    tag: 'Exterior',
  },
];
---

<section class="portfolio section" id="portafolio">
  <div class="container">
    <header class="section-header fade-in">
      <span class="eyebrow">Portafolio</span>
      <h2>Proyectos que cuentan historias</h2>
      <p>Una muestra del trabajo que hemos realizado para marcas que confían en nosotros.</p>
    </header>

    <div class="portfolio-grid">
      {projects.map((project, idx) => (
        <article class="project fade-in" style={`transition-delay: ${idx * 70}ms`}>
          <div class="project-image" style={`background: ${project.gradient}`}>
            <span class="project-tag">{project.tag}</span>
            <div class="project-overlay">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 17L17 7M17 7H8M17 7V16" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </div>
          <div class="project-info">
            <span class="project-category">{project.category}</span>
            <h3>{project.title}</h3>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio {
    background: var(--color-bg-alt);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .project {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #fff;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition), box-shadow var(--transition);
    cursor: pointer;
  }

  .project:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .project-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .project-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.15) 0%, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(0, 0, 0, 0.2) 0%, transparent 50%);
  }

  .project-tag {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    padding: 0.45rem 1rem;
    background: rgba(255, 255, 255, 0.96);
    color: var(--color-secondary);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-pill);
    z-index: 2;
    backdrop-filter: blur(4px);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.4);
    display: grid;
    place-items: center;
    opacity: 0;
    transition: opacity var(--transition);
    z-index: 1;
  }

  .project-overlay svg {
    width: 48px;
    height: 48px;
    color: #fff;
    padding: 12px;
    background: var(--color-red);
    border-radius: 50%;
    transform: scale(0.8);
    transition: transform var(--transition);
  }

  .project:hover .project-overlay {
    opacity: 1;
  }

  .project:hover .project-overlay svg {
    transform: scale(1);
  }

  .project-info {
    padding: 1.5rem 1.75rem 1.75rem;
  }

  .project-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-red);
    margin-bottom: 0.5rem;
  }

  .project-info h3 {
    font-size: 1.2rem;
    line-height: 1.35;
  }
</style>
